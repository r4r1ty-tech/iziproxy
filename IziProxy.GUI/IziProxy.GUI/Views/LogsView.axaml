<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:IziProxy.GUI.ViewModels"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="IziProxy.GUI.Views.LogsView"
             x:DataType="vm:LogsViewModel">

  <Grid RowDefinitions="Auto,*,Auto" Margin="12,12,12,24">

    <!-- Заголовок -->
    <StackPanel Grid.Row="0" Spacing="12" Margin="0,4,0,16">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <Border Background="{StaticResource PrimaryContainerBrush}"
                Width="48" Height="48"
                CornerRadius="16">
          <materialIcons:MaterialIcon Kind="ConsoleLine" Width="24" Height="24" Foreground="{StaticResource PrimaryBrush}"/>
        </Border>
        <TextBlock Text="Журнал событий" FontSize="26" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
      </StackPanel>
      
      <WrapPanel Orientation="Horizontal">
        <ToggleButton Content="Debug"
                      IsChecked="{Binding ShowDebug}"
                      Classes="Tonal"
                      Margin="0,0,8,8"/>
        <ToggleButton Content="Info"
                      IsChecked="{Binding ShowInfo}"
                      Classes="Tonal"
                      Margin="0,0,8,8"/>
        <ToggleButton Content="Error"
                      IsChecked="{Binding ShowError}"
                      Classes="Tonal"
                      Margin="0,0,8,8"/>
        <Button Content="Открыть лог-файл"
                Classes="Tonal"
                Command="{Binding OpenLogFileCommand}"
                Margin="0,0,8,8"/>
        <Button Content="Очистить"
                Classes="Tonal"
                Command="{Binding ClearLogsCommand}"
                Margin="0,0,0,8"/>
      </WrapPanel>
    </StackPanel>

    <!-- Список логов -->
    <Border Grid.Row="1" Classes="M3Card" Padding="12">
      <ListBox ItemsSource="{Binding Logs}"
               Name="LogListBox"
               Background="Transparent"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding}"
                       TextWrapping="Wrap"
                       FontFamily="Cascadia Code, Consolas, Monospace"
                       FontSize="12"
                       Foreground="#E2E2E6"
                       Padding="6,3"/>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>

    <!-- Счётчик -->
    <TextBlock Grid.Row="2"
               Text="{Binding Logs.Count, StringFormat='Сообщений: {0}'}"
               FontSize="13" Foreground="{StaticResource MutedTextBrush}"
               HorizontalAlignment="Right"
               Margin="0,8,0,0"/>
  </Grid>

</UserControl>
