<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:IziProxy.GUI.ViewModels"
             xmlns:core="using:IziProxy"
             x:Class="IziProxy.GUI.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="12" Margin="16">

      <TextBlock Text="📊 Dashboard"
                 FontSize="20" FontWeight="Bold" Margin="0,4,0,8"/>

      <!-- Нет подключения -->
      <Border Background="#2A1F1F" CornerRadius="12" Padding="16"
              IsVisible="{Binding !IsConnected}">
        <TextBlock Text="⚠️ Сначала выполните деплой на вкладке «Deploy», чтобы появилось SSH-соединение."
                   TextWrapping="Wrap" Foreground="#FF9500"/>
      </Border>

      <!-- Статус сервиса -->
      <Border Background="#1E1E2E" CornerRadius="12" Padding="16"
              IsVisible="{Binding IsConnected}">
        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">

          <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
            <TextBlock Text="Статус Xray" FontSize="12" Foreground="#888"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <!-- Цветной индикатор -->
              <Ellipse Width="12" Height="12" VerticalAlignment="Center">
                <Ellipse.Fill>
                  <SolidColorBrush Color="{Binding StatusColorHex}"/>
                </Ellipse.Fill>
              </Ellipse>
              <TextBlock Text="{Binding ServiceStatus}"
                         FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="{Binding LastUpdated, StringFormat='Обновлено: {0}'}"
                       FontSize="11" Foreground="#555"/>
          </StackPanel>

          <!-- Кнопки -->
          <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6" HorizontalAlignment="Right">
            <Button Content="🔄 Обновить"
                    Command="{Binding RefreshStatusCommand}"
                    IsEnabled="{Binding !IsBusy}"/>
            <Button Content="♻️ Перезапустить"
                    Command="{Binding RestartServiceCommand}"
                    IsEnabled="{Binding !IsBusy}"/>
          </StackPanel>

          <ProgressBar Grid.Row="1" Grid.ColumnSpan="2"
                       IsIndeterminate="True"
                       IsVisible="{Binding IsBusy}"
                       Margin="0,8,0,0"/>
        </Grid>
      </Border>

      <!-- Проверка конфига -->
      <Border Background="#1E1E2E" CornerRadius="12" Padding="16"
              IsVisible="{Binding IsConnected}">
        <StackPanel Spacing="8">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="Конфигурация Xray"
                       FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button Content="Проверить конфиг"
                    Command="{Binding ValidateConfigCommand}"
                    IsEnabled="{Binding !IsBusy}"/>
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="6"
                      IsVisible="{Binding ConfigCheckText,
                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding IsConfigValid, StringFormat={}{0:✓ Валиден|✗ Ошибка}}"
                       FontWeight="Bold"/>
            <TextBlock Text="{Binding ConfigCheckText}"
                       TextWrapping="Wrap" FontFamily="Monospace" FontSize="11"
                       Foreground="#AAA"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Трафик -->
      <StackPanel IsVisible="{Binding IsConnected}" Spacing="6">
        <TextBlock Text="Трафик по inbound'ам"
                   FontSize="15" FontWeight="SemiBold"/>

        <TextBlock Text="Нет данных (нажмите «Обновить»)"
                   Foreground="#555" FontSize="13"
                   IsVisible="{Binding TrafficStats.Count,
                     Converter={x:Static ObjectConverters.IsNull}}"/>

        <ItemsControl ItemsSource="{Binding TrafficStats}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="core:InboundTrafficStat">
              <Border Background="#1E1E2E" CornerRadius="10" Padding="14" Margin="0,4">
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <TextBlock Grid.Column="0"
                             Text="{Binding Tag}"
                             FontWeight="SemiBold" VerticalAlignment="Center"/>
                  <StackPanel Grid.Column="1" Spacing="2" Margin="16,0" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding UplinkFormatted, StringFormat='↑ {0}'}"
                               FontSize="13" Foreground="#22C55E"/>
                    <TextBlock Text="{Binding DownlinkFormatted, StringFormat='↓ {0}'}"
                               FontSize="13" Foreground="#3B82F6"/>
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
