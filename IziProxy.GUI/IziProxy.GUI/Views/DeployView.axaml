<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:IziProxy.GUI.ViewModels"
             xmlns:views="using:IziProxy.GUI.Views"
             xmlns:gui="using:IziProxy.GUI"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="IziProxy.GUI.Views.DeployView"
             x:DataType="vm:DeployViewModel">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16" Margin="12">

      <!-- Заголовок -->
      <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,8">
        <Border Background="{StaticResource PrimaryContainerBrush}"
                Width="48" Height="48"
                CornerRadius="16">
          <materialIcons:MaterialIcon Kind="ServerPlus" Width="24" Height="24" Foreground="{StaticResource PrimaryBrush}"/>
        </Border>
        <TextBlock Text="Развертывание" FontSize="26" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
      </StackPanel>

      <!-- Управление профилями -->
      <Border Classes="M3Card" Padding="16">
        <StackPanel Spacing="12">
          <TextBlock Text="Профили серверов" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
          <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">
            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding Profiles}"
                      SelectedItem="{Binding SelectedProfile}"
                      HorizontalAlignment="Stretch"
                      PlaceholderText="Выберите сохраненный профиль">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="gui:VdsProfile">
                  <TextBlock Text="{Binding Name}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Grid.Column="1"
                    Content="❌ Удалить"
                    Classes="Tonal"
                    Margin="8,0,0,0"
                    Command="{Binding DeleteProfileCommand}"
                    IsEnabled="{Binding SelectedProfile, Converter={x:Static ObjectConverters.IsNotNull}}"/>
          </Grid>
          
          <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
            <TextBox Grid.Column="0"
                     Text="{Binding NewProfileName}"
                     PlaceholderText="Имя нового профиля (напр. Мой VDS)"/>
            <Button Grid.Column="1"
                    Content="💾 Сохранить"
                    Classes="Tonal"
                    Margin="8,0,0,0"
                    Command="{Binding SaveCurrentProfileCommand}"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Форма ввода -->
      <Border Classes="M3Card" Padding="16">
        <StackPanel Spacing="16">

          <StackPanel Spacing="6">
            <TextBlock Text="IP-адрес сервера" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}"/>
            <TextBox Text="{Binding Host}"
                     PlaceholderText="1.2.3.4"
                     IsEnabled="{Binding !IsDeploying}"/>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Text="Имя пользователя" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}"/>
            <TextBox Text="{Binding Username}"
                     PlaceholderText="root"
                     IsEnabled="{Binding !IsDeploying}"/>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Text="Пароль" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}"/>
            <TextBox Text="{Binding Password}"
                     PasswordChar="●"
                     PlaceholderText="пароль (или оставьте пустым при использовании ключа)"
                     IsEnabled="{Binding !IsDeploying}"/>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Text="SSH-ключ (необязательно)" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}"/>
            <Grid ColumnDefinitions="*,Auto">
              <TextBox Grid.Column="0"
                       Text="{Binding SshKeyPath}"
                       PlaceholderText="Путь к id_rsa"
                       IsEnabled="{Binding !IsDeploying}"/>
              <Button Grid.Column="1"
                      Content="📁"
                      Classes="Tonal"
                      Margin="8,0,0,0"
                      Width="48" Height="48"
                      Command="{Binding $parent[views:DeployView].BrowseSshKey}"
                      IsEnabled="{Binding !IsDeploying}"/>
            </Grid>
          </StackPanel>

        </StackPanel>
      </Border>

      <!-- Кнопка + статус -->
      <WrapPanel Orientation="Horizontal" Margin="0,8,0,0">
        <Button Content="⚡ Проверить соединение"
                Classes="Tonal"
                Command="{Binding TestConnectionCommand}"
                IsEnabled="{Binding !IsDeploying}"
                Height="52"
                Margin="0,0,8,8"/>
        <Button Classes="Primary"
                Command="{Binding DeployCommand}"
                Height="52"
                Margin="0,0,0,8">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock Text="Установить" FontSize="16" VerticalAlignment="Center" FontWeight="Bold"/>
            <ProgressBar IsIndeterminate="True"
                         Width="20" Height="20"
                         Foreground="{StaticResource OnPrimaryBrush}"
                         IsVisible="{Binding IsDeploying}"/>
          </StackPanel>
        </Button>
      </WrapPanel>

      <TextBlock Text="{Binding StatusText}"
                 HorizontalAlignment="Center"
                 FontSize="14"
                 Foreground="{StaticResource PrimaryBrush}"
                 FontWeight="SemiBold"
                 IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

      <!-- VLESS ссылки -->
      <StackPanel IsVisible="{Binding IsCompleted}" Spacing="12">
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,4">
          <materialIcons:MaterialIcon Kind="LinkVariant" Width="22" Height="22" Foreground="#81C784"/>
          <TextBlock Text="VLESS ссылки" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
        </StackPanel>

        <ItemsControl ItemsSource="{Binding VlessLinks}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:VlessLinkItem">
              <Border Classes="M3Card" Padding="16" Margin="0,4">
                <StackPanel Spacing="10">
                  <TextBlock Text="{Binding Label}" FontWeight="Bold" FontSize="15" Foreground="{StaticResource TextBrush}"/>
                  <TextBox Text="{Binding Link}"
                           IsReadOnly="True"
                           TextWrapping="Wrap"
                           FontFamily="Cascadia Code, Consolas, Monospace"
                           FontSize="12"
                           Background="{StaticResource M3SurfaceContainerHighBrush}"/>
                  <!-- QR Code Display -->
                  <Image Source="{Binding QrCodeImage}"
                         Width="180" Height="180"
                         HorizontalAlignment="Center"
                         Margin="0,8"
                         IsVisible="{Binding QrCodeImage, Converter={x:Static ObjectConverters.IsNotNull}}"/>

                  <Grid ColumnDefinitions="*,Auto">
                    <Button Grid.Column="0"
                            Content="QR-код"
                            Classes="Tonal"
                            Command="{Binding ToggleQrCommand}"
                            HorizontalAlignment="Left"/>
                    <Button Grid.Column="1"
                            Content="{Binding CopyLabel}"
                            Classes="Tonal"
                            Command="{Binding CopyLinkCommand}"
                            HorizontalAlignment="Right"/>
                  </Grid>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
