      "tag": "direct"
    },
    {
      "protocol": "blackhole",
      "tag": "block"
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "outboundTag": "direct",
        "domain": ["geosite:ru"]
      },
      {
        "type": "field",
        "outboundTag": "direct",
        "ip": ["geoip:ru"]
      }
    ]
