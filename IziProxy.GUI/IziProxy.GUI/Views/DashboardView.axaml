<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:IziProxy.GUI.ViewModels"
             xmlns:core="using:IziProxy"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="IziProxy.GUI.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16" Margin="12,12,12,24">

      <!-- Заголовок -->
      <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,8">
        <Border Background="{StaticResource PrimaryContainerBrush}"
                Width="48" Height="48"
                CornerRadius="16">
          <materialIcons:MaterialIcon Kind="ChartBox" Width="24" Height="24" Foreground="{StaticResource PrimaryBrush}"/>
        </Border>
        <TextBlock Text="Панель состояния" FontSize="26" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
      </StackPanel>

      <!-- Нет подключения -->
      <Border Classes="M3Card"
              Background="#30FFB000"
              BorderBrush="#40FFB000"
              Padding="20"
              IsVisible="{Binding !IsConnected}">
        <StackPanel Orientation="Horizontal" Spacing="12">
          <materialIcons:MaterialIcon Kind="AlertCircleOutline" Width="24" Height="24" Foreground="#FFD54F" VerticalAlignment="Top" Margin="0,2,0,0"/>
          <TextBlock Text="Сначала выполните деплой на вкладке «Deploy», чтобы установить SSH-соединение."
                     TextWrapping="Wrap"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="#FFE082"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </Border>

      <!-- Статус сервиса -->
      <Border Classes="M3Card" Padding="20" IsVisible="{Binding IsConnected}">
        <StackPanel Spacing="16">
          <StackPanel Spacing="8">
            <TextBlock Text="Статус Xray" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}"/>
            <StackPanel Orientation="Horizontal" Spacing="10">
              <!-- Цветной индикатор -->
              <Ellipse Width="12" Height="12" VerticalAlignment="Center">
                <Ellipse.Fill>
                  <SolidColorBrush Color="{Binding StatusColorHex}"/>
                </Ellipse.Fill>
              </Ellipse>
              <TextBlock Text="{Binding ServiceStatus}"
                         FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
            </StackPanel>
            <TextBlock Text="{Binding LastUpdated, StringFormat='Обновлено: {0}'}"
                       FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
          </StackPanel>

          <!-- Кнопки -->
          <WrapPanel Orientation="Horizontal">
            <Button Content="🔄 Обновить"
                    Classes="Tonal"
                    Command="{Binding RefreshStatusCommand}"
                    IsEnabled="{Binding !IsBusy}"
                    Margin="0,0,8,8"/>
            <Button Content="♻️ Перезапустить"
                    Command="{Binding RestartServiceCommand}"
                    IsEnabled="{Binding !IsBusy}"
                    Margin="0,0,0,8"/>
          </WrapPanel>

          <ProgressBar IsIndeterminate="True"
                       IsVisible="{Binding IsBusy}"
                       Foreground="{StaticResource PrimaryBrush}"
                       Height="4"
                       Margin="0,8,0,0"/>
        </StackPanel>
      </Border>

      <!-- Проверка конфига -->
      <Border Classes="M3Card" Padding="20" IsVisible="{Binding IsConnected}">
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="4">
              <TextBlock Text="Конфигурация Xray" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
              <TextBlock Text="Проверить валидность текущего JSON конфигурационного файла на сервере" FontSize="12" Foreground="{StaticResource MutedTextBrush}"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Content="Проверить конфиг"
                    Classes="Tonal"
                    Command="{Binding ValidateConfigCommand}"
                    IsEnabled="{Binding !IsBusy}"
                    Margin="8,0,0,0"
                    VerticalAlignment="Top"/>
          </Grid>

          <Border Background="{StaticResource M3SurfaceContainerHighBrush}"
                  CornerRadius="12"
                  Padding="12"
                  IsVisible="{Binding ConfigCheckText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="{Binding IsConfigValid, StringFormat={}{0:✓ Валиден|✗ Ошибка}}"
                         FontWeight="Bold"
                         FontSize="13"
                         VerticalAlignment="Center">
                <TextBlock.Styles>
                  <Style Selector="TextBlock">
                    <Setter Property="Foreground" Value="#F2B8B5"/>
                  </Style>
                  <Style Selector="TextBlock[Text=✓ Валиден]">
                    <Setter Property="Foreground" Value="#81C784"/>
                  </Style>
                </TextBlock.Styles>
              </TextBlock>
              <TextBlock Text="{Binding ConfigCheckText}"
                         TextWrapping="Wrap"
                         FontFamily="Cascadia Code, Consolas, Monospace"
                         FontSize="12"
                         Foreground="#E2E2E6"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <!-- Трафик -->
      <StackPanel IsVisible="{Binding IsConnected}" Spacing="10">
        <TextBlock Text="Трафик по inbound'ам"
                   FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource TextBrush}"/>

        <TextBlock Text="Нет данных (нажмите «Обновить»)"
                   Foreground="{StaticResource MutedTextBrush}" FontSize="13"
                   IsVisible="{Binding TrafficStats.Count, Converter={x:Static ObjectConverters.IsNull}}"/>

        <ItemsControl ItemsSource="{Binding TrafficStats}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="core:InboundTrafficStat">
              <Border Classes="M3Card" Padding="16" Margin="0,4">
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                    <Border Background="{StaticResource PrimaryContainerBrush}"
                            Width="36" Height="36"
                            CornerRadius="18"
                            VerticalAlignment="Center">
                      <materialIcons:MaterialIcon Kind="SwapVertical" Width="18" Height="18" Foreground="{StaticResource PrimaryBrush}"/>
                    </Border>
                    <TextBlock Text="{Binding Tag}"
                               FontSize="15"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextBrush}"/>
                  </StackPanel>
                  
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <materialIcons:MaterialIcon Kind="ArrowUp" Width="16" Height="16" Foreground="#81C784"/>
                      <TextBlock Text="{Binding UplinkFormatted}"
                                 FontSize="14" FontWeight="SemiBold" Foreground="#81C784" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <materialIcons:MaterialIcon Kind="ArrowDown" Width="16" Height="16" Foreground="#64B5F6"/>
                      <TextBlock Text="{Binding DownlinkFormatted}"
                                 FontSize="14" FontWeight="SemiBold" Foreground="#64B5F6" VerticalAlignment="Center"/>
                    </StackPanel>
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
